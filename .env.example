# Clave privada de tu wallet Polygon (sin 0x)
PRIVATE_KEY=tu_clave_privada_aqui

# API Key de Polymarket CLOB (obtener en https://clob.polymarket.com)
CLOB_API_KEY=tu_api_key
CLOB_API_SECRET=tu_api_secret
CLOB_API_PASSPHRASE=tu_passphrase

# Configuración del bot
MAX_BET_USDC=10.0          # Monto máximo por apuesta en USDC
MIN_CONFIDENCE=0.65         # Confianza mínima para ejecutar (0.0 - 1.0)
DRY_RUN=true                # true = simular sin ejecutar órdenes reales

# Estrategia: MOMENTUM | CONTRARIAN | THRESHOLD
STRATEGY=THRESHOLD
THRESHOLD_BUY_YES=0.30      # Comprar YES si precio < 30%
THRESHOLD_BUY_NO=0.30       # Comprar NO si precio < 30%
